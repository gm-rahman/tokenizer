{
  "name": "figma-token-generator",
  "version": "1.0.0",
  "description": "Figma plugin that generates design-system color primitives, Light/Dark semantic tokens, and a typographic hierarchy.",
  "license": "MIT",
  "private": true,
  "type": "module",
  "scripts": {
    "build:code": "vite build --config vite.config.code.ts",
    "build:ui": "vite build --config vite.config.ui.ts",
    "build": "npm run build:code && npm run build:ui",
    "dev:code": "vite build --watch --config vite.config.code.ts",
    "dev:ui": "vite build --watch --config vite.config.ui.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "test": "vitest run"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.9.0",
    "@figma/plugin-typings": "^1.100.0",
    "@types/node": "^20.14.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "eslint": "^9.9.0",
    "eslint-plugin-react": "^7.35.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "globals": "^15.9.0",
    "typescript": "^5.5.4",
    "typescript-eslint": "^8.0.0",
    "vite": "^5.4.0",
    "vite-plugin-singlefile": "^2.0.1",
    "vitest": "^4.1.10"
  }
}
